# =============================================================================
# EGO Monorepo — Root .gitignore
# =============================================================================
# Sub-project ignores are handled by their own .gitignore files:
#   raw-ego/.gitignore           → Maven/Spring Boot build artifacts, .env
#   raw-ego-frontend/.gitignore  → node_modules, dist, .env.local
# This file only covers root-level and OS-level concerns.
# =============================================================================

# =============================================================================
# OS — macOS
# =============================================================================
.DS_Store
.AppleDouble
.LSOverride
._*

# =============================================================================
# OS — Windows
# =============================================================================
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# =============================================================================
# IDE — IntelliJ IDEA (root-level monorepo project)
# =============================================================================
.idea/
*.iml
*.iws
*.ipr

# =============================================================================
# IDE — VS Code (root-level workspace)
# =============================================================================
.vscode/
!.vscode/extensions.json

# =============================================================================
# Temporary / Scratch files
# =============================================================================
temp_zip/
*.tmp
*.bak
*.swp
*~
