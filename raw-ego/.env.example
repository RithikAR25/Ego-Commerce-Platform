# =============================================================================
# EGO Platform — Environment Variables Reference
# =============================================================================
#
# USAGE:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in values for your environment.
#   3. NEVER commit .env to git (already in .gitignore).
#
# Local development:
#   All variables here have safe defaults in application.properties.
#   You only NEED to override variables marked [REQUIRED FOR PRODUCTION].
#
# Production (Railway / VPS / Docker):
#   Set ALL variables below — do not rely on defaults.
# =============================================================================

# =============================================================================
# DATABASE — MySQL
# =============================================================================

# [REQUIRED FOR PRODUCTION]
DB_URL=jdbc:mysql://localhost:3307/rawego?serverTimezone=UTC&allowPublicKeyRetrieval=true&useSSL=false
DB_USERNAME=root
DB_PASSWORD=secret

# =============================================================================
# JWT / AUTH
# =============================================================================

# [REQUIRED FOR PRODUCTION]
# Generate: openssl rand -hex 32
# The default in application.properties is PUBLIC — override in every environment.
JWT_SECRET=your-256-bit-hex-secret-here

# =============================================================================
# REDIS
# =============================================================================

# Used for: cart storage, checkout locking, access token blocklist
# Default: localhost:6379 (no password)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# CLOUDINARY — Image CDN
# =============================================================================

# [REQUIRED FOR IMAGE UPLOAD]
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# 'dev' or 'prod' — controls folder prefix: ego/{env}/products/...
CLOUDINARY_ENV=dev

# =============================================================================
# RAZORPAY — Payment Gateway
# =============================================================================

# [REQUIRED FOR CHECKOUT]
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Set in Razorpay Dashboard → Settings → Webhooks → your endpoint → Secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# =============================================================================
# SENDGRID — Transactional Email
# =============================================================================

# [REQUIRED FOR EMAIL NOTIFICATIONS]
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# Must be a verified sender in SendGrid Dashboard → Settings → Sender Authentication
SENDGRID_FROM_EMAIL=noreply@ego.com

# =============================================================================
# ELASTICSEARCH
# =============================================================================

# Default: http://localhost:9200 (Docker container: ego-elasticsearch)
# Production: set to your managed ES cluster URL (Elastic Cloud, Railway plugin, etc.)
ES_HOST=http://localhost:9200

# =============================================================================
# APPLICATION URLS
# =============================================================================

# Frontend base URL — used to build email verification links.
# Production: set to your deployed frontend domain.
APP_BASE_URL=https://ego.com

# =============================================================================
# SPRING DEVELOPMENT OVERRIDES
# =============================================================================

# Enable SQL logging locally (disabled by default in application.properties)
# SPRING_SHOW_SQL=true

# Enable Hibernate SQL query logging in the console (OFF by default \u2014 never enable in production).
# Set this in your LOCAL .env only. Produces one log line per SQL statement \u2014 useful for debugging N+1s.
# HIBERNATE_SQL_LOG_LEVEL=DEBUG

# =============================================================================
# FRONTEND (Vite .env — place in raw-ego-frontend/)
# =============================================================================

# Copy the following to raw-ego-frontend/.env.local for local dev:
#
# VITE_API_BASE_URL=http://localhost:8080/api/v1
# VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
